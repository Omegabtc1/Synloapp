# Copy this file to:  client/.env
# Vite only exposes variables that start with VITE_

# --- Local dev (recommended) ---
# Leave both empty: the UI calls /api and /socket.io on the same origin (Vite dev server),
# and vite.config.js proxies those to the API on port 5000.
VITE_API_URL=
VITE_SOCKET_URL=

# --- Production / preview (real API host) ---
# No trailing slash. Example:
# VITE_API_URL=https://api.yourdomain.com
# VITE_SOCKET_URL=https://api.yourdomain.com
