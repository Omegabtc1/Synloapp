#
# Copy to `server/.env` and `client/.env` for local development.
#
#
# server/.env
# DATABASE_URL="file:./dev.db"
# JWT_SECRET="replace-with-64-char-random-string-in-production"
# PORT=5000
# CLIENT_URL="http://localhost:5173"
# NODE_ENV=development
#
# client/.env (local dev — recommended: use Vite proxy)
# Leave empty so the browser calls same-origin /api and /socket.io (proxied to :5000).
# VITE_API_URL=
# VITE_SOCKET_URL=
#
# Optional: talk to API directly (same machine only; can complicate cookies)
# VITE_API_URL=http://localhost:5000
# VITE_SOCKET_URL=http://localhost:5000

