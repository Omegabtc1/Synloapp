{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd creatorbrand && npm install",
  "buildCommand": "cd creatorbrand && npm run build -w client",
  "outputDirectory": "creatorbrand/client/dist",
  "rewrites": [
    {
      "source": "/((?!assets/|socket\\.io).*)",
      "destination": "/index.html"
    }
  ]
}
