# Copy to `server/.env` and `client/.env` for local development.
#
#
# server/.env
# DATABASE_URL="file:./dev.db"
# JWT_SECRET="replace-with-64-char-random-string-in-production"
# PORT=5000
# CLIENT_URL="http://localhost:5173"
# NODE_ENV=development
#
# client/.env
# VITE_API_URL=http://localhost:5000
# VITE_SOCKET_URL=http://localhost:5000

